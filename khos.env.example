# KHAOS Environment Configuration (opcional)
# Copie para .khos.env e preencha suas chaves
# Este arquivo é carregado automaticamente pelo activate.py

# ── LLM Provider ─────────────────────────────────
# Provider: ollama-cloud, openai, anthropic, openrouter, ollama-local, xai
KHAOS_PROVIDER=ollama-cloud
KHAOS_MODEL=gemma4:31b

# LLM API Key (ou usar variável de ambiente do provider)
# KHAOS_API_KEY=

# ── Honcho (memória persistente) ─────────────────
# Necessário para memória entre sessões
# Obtenha em: https://app.honcho.dev/api-keys
KHAOS_HONCHO_KEY=hch-v3-hl78k2xl0ufi0494f4kjodgfqyqhtkg87tarb8z731okrukgtye2k3fmaybd9lo9
KHAOS_HONCHO_WORKSPACE=khaos

# ── Jailbreak Strategy ──────────────────────────
# refusal_inversion (gemma4), og_godmode (GPT), direct_godmode, pliny_love
KHAOS_STRATEGY=refusal_inversion